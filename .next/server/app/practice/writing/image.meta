{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/practice/layout,_N_T_/practice/writing/layout,_N_T_/practice/writing/image/layout,_N_T_/practice/writing/image/page,_N_T_/practice/writing/image"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/practice/writing/image/__PAGE__",
    "/practice/writing/image",
    "/practice/writing",
    "/practice",
    "/_index",
    "/_head"
  ]
}