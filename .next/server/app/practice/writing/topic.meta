{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/practice/layout,_N_T_/practice/writing/layout,_N_T_/practice/writing/topic/layout,_N_T_/practice/writing/topic/page,_N_T_/practice/writing/topic"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/practice/writing/topic/__PAGE__",
    "/practice/writing/topic",
    "/practice/writing",
    "/practice",
    "/_index",
    "/_head"
  ]
}